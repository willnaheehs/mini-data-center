{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "sum by (policy, job_type) (increase(mini_dc_dispatch_jobs_submitted_total[6h]))",
          "legendFormat": "{{policy}} {{job_type}}",
          "refId": "A"
        }
      ],
      "title": "Submitted Jobs by Policy and Type",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "mini_dc_dispatch_sleep_duration_seconds",
          "legendFormat": "sleep {{target_worker}}",
          "refId": "A"
        },
        {
          "expr": "mini_dc_dispatch_cpu_work_units",
          "legendFormat": "cpu {{target_worker}}",
          "refId": "B"
        }
      ],
      "title": "Latest Submitted Job Size",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "mini_dc_worker_sleep_duration_seconds",
          "legendFormat": "{{worker_name}} sleep",
          "refId": "A"
        },
        {
          "expr": "mini_dc_worker_cpu_work_units",
          "legendFormat": "{{worker_name}} cpu",
          "refId": "B"
        }
      ],
      "title": "Latest Processed Job Size",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "dateTimeAsIso"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "mini_dc_worker_last_job_timestamp * 1000",
          "legendFormat": "{{worker_name}}",
          "refId": "A"
        }
      ],
      "title": "Last Job Timestamp",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "Loki"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "{job=~\"container-logs|system-logs|mini-dc-results\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Workload Activity Logs",
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mini-data-center", "workload", "activity"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "Workload Activity",
  "uid": "mini-dc-workload-activity",
  "version": 1
}
