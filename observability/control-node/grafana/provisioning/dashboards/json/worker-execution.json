{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "sum by (worker_name, job_type, status) (rate(mini_dc_worker_jobs_processed_total[5m]))",
          "legendFormat": "{{worker_name}} {{job_type}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Processed Jobs Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "mini_dc_worker_busy",
          "legendFormat": "{{worker_name}}",
          "refId": "A"
        }
      ],
      "title": "Worker Busy State",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, worker_name) (rate(mini_dc_worker_wait_seconds_bucket[5m])))",
          "legendFormat": "{{worker_name}} p95 wait",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, worker_name) (rate(mini_dc_worker_service_seconds_bucket[5m])))",
          "legendFormat": "{{worker_name}} p95 service",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, worker_name) (rate(mini_dc_worker_total_seconds_bucket[5m])))",
          "legendFormat": "{{worker_name}} p95 total",
          "refId": "C"
        }
      ],
      "title": "P95 Job Timing",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "sum by (worker_name, job_type) (increase(mini_dc_worker_job_failures_total[6h]))",
          "legendFormat": "{{worker_name}} {{job_type}}",
          "refId": "A"
        }
      ],
      "title": "Worker Failures",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "sum by (worker_name, target_worker) (increase(mini_dc_worker_target_mismatch_total[6h]))",
          "legendFormat": "{{worker_name}} target={{target_worker}}",
          "refId": "A"
        }
      ],
      "title": "Target vs Actual Worker Mismatch",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "Loki"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 6,
      "targets": [
        {
          "expr": "{job=~\"container-logs|system-logs\"} |= \"Worker\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Worker Logs",
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mini-data-center", "worker"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "Worker Execution",
  "uid": "mini-dc-worker-execution",
  "version": 1
}
