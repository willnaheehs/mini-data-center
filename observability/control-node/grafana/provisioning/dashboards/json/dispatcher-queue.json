      "id": 1,
      "targets": [
        {
          "expr": "sum by (policy, target_worker) (rate(mini_dc_dispatch_jobs_submitted_total[5m]))",
          "legendFormat": "{{policy}} -> {{target_worker}}",
          "refId": "A"
        }
      ],
      "title": "Dispatch Rate by Policy and Target Worker",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "mini_dc_dispatch_queue_length",
          "legendFormat": "{{worker}} {{queue}}",
          "refId": "A"
        }
      ],
      "title": "Observed Queue Length at Dispatch",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
